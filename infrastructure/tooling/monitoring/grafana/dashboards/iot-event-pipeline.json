{
    "id": null,
    "title": "EcoTrack IoT Event Pipeline",
    "tags": ["ecotrack", "iot", "observability"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "gnetId": null,
    "graphTooltip": 0,
    "hideControls": false,
    "links": [],
    "refresh": "30s",
    "rows": [
      {
        "collapse": false,
        "height": "280px",
        "title": "Hop Overview",
        "panels": [
          {
            "title": "Service Hop Throughput",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (hop,outcome) (rate(ecotrack_service_hop_events_total[5m]))",
                "legendFormat": "{{hop}} {{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 0, "y": 0 },
            "id": 1
          },
          {
            "title": "Service Hop P95 Latency",
            "type": "graph",
            "targets": [
              {
                "expr": "histogram_quantile(0.95, sum by (le, hop) (rate(ecotrack_service_hop_duration_ms_bucket[5m])))",
                "legendFormat": "{{hop}} p95"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 8, "y": 0 },
            "id": 2
          },
          {
            "title": "Service Hop P99 Latency",
            "type": "graph",
            "targets": [
              {
                "expr": "histogram_quantile(0.99, sum by (le, hop) (rate(ecotrack_service_hop_duration_ms_bucket[5m])))",
                "legendFormat": "{{hop}} p99"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
            "id": 3
          }
        ]
      },
      {
        "collapse": false,
        "height": "280px",
        "title": "Eight Logical Hops",
        "panels": [
          {
            "title": "HTTP Ingestion to Staging",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"ingest_http_to_staging\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 0, "y": 9 },
            "id": 4
          },
          {
            "title": "Staged Event Claims",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"staged_event_claim\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 3, "y": 9 },
            "id": 5
          },
          {
            "title": "Validation and Enrichment",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"staged_queue_to_validation\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 6, "y": 9 },
            "id": 6
          },
          {
            "title": "Validated Delivery Claims",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"validated_delivery_claim\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 9, "y": 9 },
            "id": 7
          },
          {
            "title": "Timeseries Projection",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"delivery_to_timeseries_projection\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 12, "y": 9 },
            "id": 8
          },
          {
            "title": "Rollup Projection",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"delivery_to_rollup_projection\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 15, "y": 9 },
            "id": 9
          },
          {
            "title": "Zone Analytics Projection",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"delivery_to_zone_analytics_projection\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 18, "y": 9 },
            "id": 16
          },
          {
            "title": "Anomaly Alert Projection",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (outcome) (rate(ecotrack_service_hop_events_total{hop=\"delivery_to_anomaly_alert_projection\"}[5m]))",
                "legendFormat": "{{outcome}}"
              }
            ],
            "gridPos": { "h": 9, "w": 3, "x": 21, "y": 9 },
            "id": 17
          }
        ]
      },
      {
        "collapse": false,
        "height": "280px",
        "title": "Lag, Backlog, and Connector Exports",
        "panels": [
          {
            "title": "Pipeline Backlog",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_iot_ingestion_backlog_total",
                "legendFormat": "ingestion backlog"
              },
              {
                "expr": "ecotrack_iot_validated_delivery_backlog_total",
                "legendFormat": "validated delivery backlog"
              },
              {
                "expr": "ecotrack_event_connector_backlog_total",
                "legendFormat": "event connector backlog"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 0, "y": 18 },
            "id": 10
          },
          {
            "title": "Lag By Consumer",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_internal_consumer_lag_messages",
                "legendFormat": "{{consumer}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 8, "y": 18 },
            "id": 11
          },
          {
            "title": "Oldest Pending Age By Consumer",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_internal_consumer_lag_oldest_pending_age_ms",
                "legendFormat": "{{consumer}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 16, "y": 18 },
            "id": 12
          }
        ]
      },
      {
        "collapse": false,
        "height": "280px",
        "title": "Shard Distribution",
        "panels": [
          {
            "title": "Ingestion Backlog By Shard",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_iot_ingestion_shard_backlog",
                "legendFormat": "shard {{shard}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 0, "y": 27 },
            "id": 13
          },
          {
            "title": "Validated Delivery Backlog By Consumer and Shard",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_iot_validated_delivery_shard_backlog",
                "legendFormat": "{{consumer}} shard {{shard}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 8, "y": 27 },
            "id": 14
          },
          {
            "title": "Consumer Shard Skew",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_internal_consumer_lag_shard_skew",
                "legendFormat": "{{consumer}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 16, "y": 27 },
            "id": 15
          }
        ]
      }
    ],
    "schemaVersion": 14,
    "version": 2,
    "templating": { "list": [] },
    "time": { "from": "now-1h", "to": "now" },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
  "annotations": { "list": [] }
}
