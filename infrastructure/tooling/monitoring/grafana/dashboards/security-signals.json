{
    "id": null,
    "title": "EcoTrack Security Signals Baseline",
    "tags": ["ecotrack", "security", "observability"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "gnetId": null,
    "graphTooltip": 0,
    "hideControls": false,
    "links": [],
    "refresh": "30s",
    "rows": [
      {
        "collapse": false,
        "height": "280px",
        "title": "HTTP and Runtime Security Signals",
        "panels": [
          {
            "title": "Derived Security Signals",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (signal,severity) (rate(ecotrack_security_signals_total[5m]))",
                "legendFormat": "{{signal}} {{severity}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 0, "y": 0 },
            "id": 1
          },
          {
            "title": "401 / 403 / 429 / 5xx Status Counts",
            "type": "graph",
            "targets": [
              {
                "expr": "sum by (status_code) (increase(ecotrack_http_request_status_total{status_code=~\"401|403|429|500|502|503|504\"}[5m]))",
                "legendFormat": "{{status_code}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 8, "y": 0 },
            "id": 2
          },
          {
            "title": "Login Failure Signals",
            "type": "graph",
            "targets": [
              {
                "expr": "increase(ecotrack_security_signals_total{signal=\"login_failure\"}[15m])",
                "legendFormat": "login failures / 15m"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
            "id": 3
          }
        ]
      },
      {
        "collapse": false,
        "height": "280px",
        "title": "Realtime and Admin Activity",
        "panels": [
          {
            "title": "WebSocket Auth Failures",
            "type": "graph",
            "targets": [
              {
                "expr": "increase(ecotrack_realtime_connection_events_total{transport=\"ws\",action=\"auth_failure\"}[10m])",
                "legendFormat": "ws auth failures / 10m"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 0, "y": 9 },
            "id": 4
          },
          {
            "title": "Admin Validation Failures",
            "type": "graph",
            "targets": [
              {
                "expr": "increase(ecotrack_security_signals_total{signal=\"admin_validation_failed\"}[15m])",
                "legendFormat": "admin validation failures / 15m"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 8, "y": 9 },
            "id": 5
          },
          {
            "title": "Admin Audit Actions Last Hour",
            "type": "graph",
            "targets": [
              {
                "expr": "ecotrack_admin_audit_actions_last_hour",
                "legendFormat": "{{action}}"
              }
            ],
            "gridPos": { "h": 9, "w": 8, "x": 16, "y": 9 },
            "id": 6
          }
        ]
      }
    ],
    "schemaVersion": 14,
    "version": 1,
    "templating": { "list": [] },
    "time": { "from": "now-1h", "to": "now" },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
  "annotations": { "list": [] }
}
