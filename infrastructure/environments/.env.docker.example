# Docker dev template (copy to infrastructure/environments/.env.docker)
NODE_ENV=development
API_PORT=3001
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=ecotrack-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_TRACES_SAMPLER_RATIO=1
ROUTING_API_BASE_URL=https://router.project-osrm.org
ROUTING_TIMEOUT_MS=10000
ROUTING_FAILURE_THRESHOLD=5
ROUTING_RESET_WINDOW_MS=30000
IOT_INGESTION_ENABLED=false
IOT_QUEUE_CONCURRENCY=50
IOT_QUEUE_BATCH_SIZE=500
IOT_BACKPRESSURE_THRESHOLD=100000
IOT_MAX_BATCH_SIZE=1000
IOT_VALIDATED_CONSUMER_CONCURRENCY=20
IOT_VALIDATED_CONSUMER_BATCH_SIZE=250
IOT_INGESTION_SHARD_COUNT=12
IOT_VALIDATED_CONSUMER_SHARD_COUNT=12
PLANNING_SSE_ENABLED=false
PLANNING_WEBSOCKET_ENABLED=true
PLANNING_REALTIME_INTERVAL_MS=300000
PLANNING_REPORTS_ENABLED=false
ADMIN_WORKSPACE_ENABLED=false
BILLING_ENABLED=false
CITIZEN_CHALLENGES_ENABLED=false
DATABASE_URL=postgres://postgres:postgres@ticket_db:5432/ecotrack
DATABASE_POOLER_URL=
DATABASE_POOL_MAX=5
CACHE_ENABLED=true
CACHE_PREFIX=ecotrack
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=300
CACHE_PLANNING_TTL_SECONDS=300
CACHE_ANALYTICS_TTL_SECONDS=60
CACHE_CITIZEN_TTL_SECONDS=30
CACHE_MAX_MEMORY_ENTRIES=250
CACHE_REDIS_URL=
RESPONSE_COMPRESSION_ENABLED=true
RESPONSE_COMPRESSION_THRESHOLD_BYTES=1024
RESPONSE_COMPRESSION_LEVEL=6

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecotrack

SESSION_SECRET=CHANGE_ME_SESSION_SECRET
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m
API_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend URL should stay at origin/root (no /auth or legacy app-page suffixes).
APP_URL=http://localhost:3000
# Keep this list limited to the active Docker dev frontend origin.
CORS_ORIGINS=http://localhost:3000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_LOGSTASH=false
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5001
ELASTIC_URL=http://elasticsearch:9200
ALERTMANAGER_DEV_WEBHOOK_URL=http://alert-webhook-sink:8080/alerts
ALERTMANAGER_WARNING_RECEIVER=dev-webhook
ALERTMANAGER_CRITICAL_RECEIVER=dev-webhook
ALERTMANAGER_GROUP_WAIT=30s
ALERTMANAGER_GROUP_INTERVAL=5m
ALERTMANAGER_REPEAT_INTERVAL=4h
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_SLACK_CHANNEL=ecotrack-alerts
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=
# Jaeger UI is exposed at http://localhost:16686 when the obs profile is enabled.

CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

