{
  "name": "ecotrack-infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docker:dev": "docker compose --env-file ./environments/.env.docker -f docker-compose.yml --profile core up --build -d",
    "docker:down": "docker compose --env-file ./environments/.env.docker -f docker-compose.yml --profile core down --remove-orphans",
    "obs:up": "docker compose --env-file ./environments/.env.docker -f docker-compose.yml --profile obs up -d",
    "obs:down": "docker compose --env-file ./environments/.env.docker -f docker-compose.yml --profile obs down --remove-orphans",
    "health": ".\\scripts\\host-bash\\health-check.bat",
    "smoke": "node ./scripts/smoke-docker.mjs",
    "chaos:iot": "node ./scripts/iot-chaos-harness.mjs",
    "verify:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-docker.ps1"
  }
}
