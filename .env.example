# Canonical local/native development template (copy to .env)
# Private keys are placeholders. Do not commit populated .env files.

NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecotrack
DATABASE_POOL_MAX=5
# Optional PgBouncer listener for runtime traffic. Keep migrations on DATABASE_URL.
DATABASE_POOLER_URL=
# Optional Supabase project URL for API-side JWT verification when Supabase Auth is enabled.
SUPABASE_URL=
# Server-only one-off admin/import key for Supabase Auth migration scripts. Never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=

# Auth
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m

# OAuth
# Must be a Google Web OAuth client ID:
# <numeric-project-id>-<client>.apps.googleusercontent.com
GOOGLE_CLIENT_ID=1234567890-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
API_BASE_URL=http://localhost:5173
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# Client access
# Comma-separated exact frontend origins allowed to call API/WS from browsers.
# Keep temporary team origins time-boxed and remove when no longer needed.
CORS_ORIGINS=http://localhost:5173

# Request hardening and logging (optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOG_LEVEL=info
LOG_FORMAT=pretty
OTEL_TRACING_ENABLED=false
OTEL_SERVICE_NAME=ecotrack-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER_RATIO=1
ROUTING_API_BASE_URL=https://router.project-osrm.org
ROUTING_TIMEOUT_MS=10000
ROUTING_FAILURE_THRESHOLD=5
ROUTING_RESET_WINDOW_MS=30000
IOT_INGESTION_ENABLED=true
IOT_QUEUE_CONCURRENCY=50
IOT_QUEUE_BATCH_SIZE=500
IOT_BACKPRESSURE_THRESHOLD=100000
IOT_MAX_BATCH_SIZE=1000
IOT_VALIDATED_CONSUMER_CONCURRENCY=20
IOT_VALIDATED_CONSUMER_BATCH_SIZE=250
IOT_INGESTION_SHARD_COUNT=12
IOT_VALIDATED_CONSUMER_SHARD_COUNT=12
CACHE_ENABLED=true
CACHE_PREFIX=ecotrack
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=30
CACHE_PLANNING_TTL_SECONDS=20
CACHE_ANALYTICS_TTL_SECONDS=60
CACHE_CITIZEN_TTL_SECONDS=30
CACHE_MAX_MEMORY_ENTRIES=250
CACHE_REDIS_URL=
RESPONSE_COMPRESSION_ENABLED=true
RESPONSE_COMPRESSION_THRESHOLD_BYTES=1024
RESPONSE_COMPRESSION_LEVEL=6

# Optional alerts/observability
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_LOGSTASH=false
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5001
ELASTIC_URL=http://localhost:9200
ALERTMANAGER_DEV_WEBHOOK_URL=http://localhost:8085/alerts
ALERTMANAGER_WARNING_RECEIVER=dev-webhook
ALERTMANAGER_CRITICAL_RECEIVER=dev-webhook
ALERTMANAGER_GROUP_WAIT=30s
ALERTMANAGER_GROUP_INTERVAL=5m
ALERTMANAGER_REPEAT_INTERVAL=4h
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_SLACK_CHANNEL=ecotrack-alerts
ALERTMANAGER_PAGERDUTY_ROUTING_KEY=
# Jaeger UI runs at http://localhost:16686 when the Docker obs profile is enabled.

# SonarCloud (CI quality gate; keep in secure secret store for CI)
SONAR_ORGANIZATION=CHANGE_ME_SONAR_ORGANIZATION
SONAR_PROJECT_KEY=CHANGE_ME_SONAR_PROJECT_KEY
SONAR_TOKEN=CHANGE_ME_SONAR_TOKEN

# Optional Sentry release upload credentials for build-time source maps
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=

# Optional CDN / purge automation
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

