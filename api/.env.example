# API template (private keys are placeholders)
NODE_ENV=development
API_PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecotrack

# Auth
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=15m

# OAuth
# Must be a Google Web OAuth client ID:
# <numeric-project-id>-<client>.apps.googleusercontent.com
GOOGLE_CLIENT_ID=1234567890-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# CORS
CORS_ORIGINS=http://localhost:5173

# Request hardening and logging (optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
LOG_LEVEL=info
LOG_FORMAT=pretty
ENABLE_LOGSTASH=false
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5001
IOT_INGESTION_ENABLED=false
IOT_QUEUE_CONCURRENCY=50
IOT_QUEUE_BATCH_SIZE=500
IOT_BACKPRESSURE_THRESHOLD=100000
IOT_MAX_BATCH_SIZE=1000
IOT_VALIDATED_CONSUMER_CONCURRENCY=20
IOT_VALIDATED_CONSUMER_BATCH_SIZE=250
IOT_INGESTION_SHARD_COUNT=12
IOT_VALIDATED_CONSUMER_SHARD_COUNT=12
CACHE_DASHBOARD_TTL_SECONDS=300
CACHE_PLANNING_TTL_SECONDS=300
PLANNING_SSE_ENABLED=false
PLANNING_WEBSOCKET_ENABLED=true
PLANNING_REALTIME_INTERVAL_MS=300000
PLANNING_REPORTS_ENABLED=false
ADMIN_WORKSPACE_ENABLED=false
BILLING_ENABLED=false
CITIZEN_CHALLENGES_ENABLED=false

# SonarCloud (CI quality gate; keep in secure secret store for CI)
SONAR_ORGANIZATION=CHANGE_ME_SONAR_ORGANIZATION
SONAR_PROJECT_KEY=CHANGE_ME_SONAR_PROJECT_KEY
SONAR_TOKEN=CHANGE_ME_SONAR_TOKEN

